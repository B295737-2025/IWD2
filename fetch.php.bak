<?php
$family = $_POST['family'] ?? '';
$taxon  = $_POST['taxon'] ?? '';

$family = trim($family);
$taxon  = trim($taxon);
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fetch Sequences</title>
</head>
<body>
    <h1>Fetch Sequences</h1>

    <?php if ($family === '' || $taxon === ''): ?>
        <p>Error: missing protein family or taxonomic group.</p>
    <?php else: ?>
        <p><strong>Protein family:</strong> <?php echo htmlspecialchars($family); ?></p>
        <p><strong>Taxonomic group:</strong> <?php echo htmlspecialchars($taxon); ?></p>
        <p>The next step will be to query NCBI using Bio.Entrez and download FASTA sequences.</p>
    <?php endif; ?>

    <p><a href="index.php">Back to home</a></p>
</body>
</html>