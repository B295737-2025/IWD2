<?php
$input_file = $_GET['file'] ?? '';
$input_file = trim($input_file);

$results_dir = realpath(__DIR__ . '/results');

function error_page($message) {
    ?>
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Motif Scan</title>
    </head>
    <body>
        <h1>Motif Scan</h1>
        <p><strong>Error:</strong> <?php echo htmlspecialchars($message); ?></p>
        <p><a href="index.php">Back to home</a></p>
    </body>
    </html>
    <?php
    exit;
}

if ($input_file === '') {
    error_page('No input FASTA file was provided.');
}

$relative_input = ltrim($input_file, '/');
$absolute_input = realpath(__DIR__ . '/' . $relative_input);

if ($absolute_input === false || strpos($absolute_input, $results_dir) !== 0) {
    error_page('Invalid input file path.');
}

if (!file_exists($absolute_input)) {
    error_page('Input FASTA file does not exist.');
}

$input_basename = pathinfo($absolute_input, PATHINFO_FILENAME);
$motif_basename = $input_basename . '.patmatmotifs';
$motif_absolute = $results_dir . '/' . $motif_basename;
$motif_relative = 'results/' . $motif_basename;

$patmat = '/usr/bin/patmatmotifs';

$run_output = '';

if (!file_exists($motif_absolute)) {
    $command = $patmat
        . ' -sequence ' . escapeshellarg($absolute_input)
        . ' -outfile ' . escapeshellarg($motif_absolute)
        . ' -full Y -auto 2>&1';

    $run_output = shell_exec($command);

    if (!file_exists($motif_absolute)) {
        error_page("patmatmotifs failed.<br><pre>" . htmlspecialchars($run_output) . "</pre>");
    }
}

$report_text = file_get_contents($motif_absolute);
if ($report_text === false) {
    error_page('Could not read motif report file.');
}

$hitcount = null;
if (preg_match('/# HitCount:\s*([0-9]+)/', $report_text, $matches)) {
    $hitcount = (int)$matches[1];
}
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Motif Scan</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 950px;
            margin: 40px auto;
            line-height: 1.6;
            padding: 0 20px;
        }
        .box {
            border: 1px solid #ccc;
            padding: 20px;
            border-radius: 8px;
            background: #f9f9f9;
            margin-bottom: 20px;
        }
        h1, h2 {
            color: #1f4e79;
        }
        a {
            color: #1f4e79;
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }
        pre {
            white-space: pre-wrap;
            word-break: break-word;
            background: #f3f3f3;
            padding: 12px;
            border-radius: 6px;
            overflow-x: auto;
        }
        .note {
            color: #555;
        }
    </style>
</head>
<body>
    <h1>Motif / Domain Scan</h1>

    <div class="box">
        <h2>Input and output files</h2>
        <p><strong>Input FASTA:</strong> <a href="<?php echo htmlspecialchars($relative_input); ?>"><?php echo htmlspecialchars($relative_input); ?></a></p>
        <p><strong>Motif report:</strong> <a href="<?php echo htmlspecialchars($motif_relative); ?>"><?php echo htmlspecialchars($motif_relative); ?></a></p>
        <p class="note">
            Result files are retained on the server for 60 days.
            You can revisit recent analyses from the history page during this period.
        </p>
    </div>

    <div class="box">
        <h2>Scan summary</h2>
        <?php if ($hitcount === null): ?>
            <p>HitCount could not be parsed from the report.</p>
        <?php else: ?>
            <p><strong>HitCount:</strong> <?php echo htmlspecialchars((string)$hitcount); ?></p>
            <?php if ($hitcount === 0): ?>
                <p>No PROSITE motif was reported in this scan.</p>
            <?php endif; ?>
        <?php endif; ?>
    </div>

    <div class="box">
        <h2>Raw patmatmotifs report</h2>
        <pre><?php echo htmlspecialchars($report_text); ?></pre>
    </div>

    <p><a href="index.php">Back to home</a></p>
    <p><a href="history.php">View history</a></p>
</body>
</html>